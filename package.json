{
  "name": "@darkforgeai/agentbridge",
  "version": "0.1.0",
  "description": "Production-ready multi-agent coordination layer with A2A protocol and MCP support",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "agentbridge": "dist/server/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "start:mcp": "node dist/mcp/index.js",
    "test": "tsx --test tests/*.test.ts",
    "seed": "tsx scripts/seed.ts",
    "docker:build": "docker build -t agentbridge .",
    "docker:run": "docker compose up",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "public",
    "README.md"
  ],
  "keywords": [
    "agents",
    "a2a",
    "mcp",
    "multi-agent",
    "orchestration",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pamperito74/AgentBridge.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "pino": "^10.3.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
