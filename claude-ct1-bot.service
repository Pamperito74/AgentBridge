[Unit]
Description=AgentBridge Bot (OpenAI-compatible LLM)
After=network.target agentbridge.service
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
User=doceno
WorkingDirectory=/Users/doceno/code/TheDarkFactory/AgentBridge

# Secrets — create this file on the server before enabling the service:
#   sudo mkdir -p /etc/agentbridge
#   sudo tee /etc/agentbridge/bot.env <<'EOF'
#   AGENTBRIDGE_TOKEN=your-token-here
#   LLM_API_KEY=your-key-if-needed
#   EOF
EnvironmentFile=-/etc/agentbridge/bot.env

# Identity
Environment=BOT_NAME=claude-ct1
Environment=BOT_ROLE=AI coding agent — AgentBridge + CirrusTranslate
Environment=BOT_CAPABILITIES=code-review,backend,typescript,python,agentbridge,nestjs,react

# LLM — pick ONE backend, comment out the others:
#
#   Claude CLI (installed on server, no API key needed):
Environment=LLM_COMMAND=claude
#
#   Ollama (local, no API key):
#Environment=LLM_COMMAND=ollama run llama3.2
#
#   OpenAI-compatible HTTP (set LLM_API_KEY in /etc/agentbridge/bot.env):
#Environment=LLM_BASE_URL=https://api.groq.com/openai/v1
#Environment=LLM_MODEL=llama-3.3-70b-versatile

# Bridge
Environment=AGENTBRIDGE_URL=ws://172.31.141.155:7890
Environment=AGENTBRIDGE_HTTP_URL=http://172.31.141.155:7890
Environment=BOT_CONTEXT_MESSAGES=10

ExecStart=/usr/bin/python3 /Users/doceno/code/TheDarkFactory/AgentBridge/bot.py
Restart=always
RestartSec=5

MemoryMax=256M
CPUQuota=25%

StandardOutput=journal
StandardError=journal
SyslogIdentifier=agentbridge-bot

NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
