[Unit]
Description=AgentBridge Inter-Agent Communication Server
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
User=doceno
WorkingDirectory=/Users/doceno/code/TheDarkFactory/AgentBridge
ExecStart=/Users/doceno/code/TheDarkFactory/AgentBridge/run_server.py
Restart=always
RestartSec=3

# Resource limits
MemoryMax=512M
CPUQuota=50%

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agentbridge

# Security
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
